<?xml version="1.0" encoding="UTF-8"?>
<gexf
  kitab:version="0.1.0.0"
  version="1.2"
  xmlns="http://www.gexf.net/1.2draft">
    <graph defaultedgetype="directed" mode="static">
        <attributes class="node">
            <attribute
              id="context"
              title="context"
              type="string"/>
        </attributes>
        <nodes>
            <node id="my-app" label="my-app">
                <attvalues>
                    <attvalue for="context" value="k8s"/>
                </attvalues>
            </node>
            <node id="network" label="network"/>
        </nodes>
        <edges>
            <edge
              id="e0"
              label="network"
              source="my-app"
              target="network"/>
        </edges>
    </graph>
</gexf>
