context "k8s"

service "main-app" {
	in-context "k8s"

	connect "postgres"

	depends-on "rabbitmq" {
		via "https"
	}
}

cidr-set "postgres" puml:type="database" {
	cidr-rule {
		cidr "10.42.42.0/24" "PostgreSQL Cluster"
	}
	port 5432
}

service "rabbitmq" puml:type="queue" {
	in-context "k8s"
	port 5672
}
