context "k8s"

service "opensearch" {
   fqdn "opensearch.internal.network"
}

service "otel-tracing" {
   fqdn "tracing.internal.network"
}

service "redis" {
	context "k8s"
}

service "media-proxy" {
	context "k8s"
	depends-on "opensearch" {
		via "https"
	}
	depends-on "otel-tracing" {
		via "https"
		port 4317
	}
	depends-on "redis" {
		port 6379
		via "https"
	}
}
