packages:
  ./
  kitab-prelude

with-compiler: ghc-9.12.2

test-show-details: direct

optimization: False

documentation: False

profiling: True

package *
  profiling-detail: none
  ghc-options: -fprof-auto -fprof-auto-calls -haddock -finfo-table-map -fwrite-ide-info

tests: True

semaphore: True

multi-repl: True
